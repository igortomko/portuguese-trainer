{
  "version": 2,
  "builds": [
    { "src": "api/linear-done.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/linear-done", "dest": "/api/linear-done.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
